{{ 'section-announcement-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    --ab-text-color: {{ section.settings.text_color }};
  }
{%- endstyle -%}

<div
  class="page-width section-announcement-bar"
  {{ section.shopify_attributes }}>

  {% if section.blocks.size > 0 %}
    {% if section.blocks.size == 1 %}
      <!-- Affichage simple si 1 seul block -->
      <div class="section-announcement-bar__content">
        <div class="section-announcement-bar__text">{{ section.blocks.first.settings.text }}</div>
      </div>
    {% else %}
      <!-- Carousel Swiper si plusieurs blocks -->
      <div class="section-announcement-bar__wrapper">
        <button class="section-announcement-bar__btn section-announcement-bar__btn--prev" data-prev-announcement></button>

        <div class="swiper section-announcement-bar__swiper" data-announcement-swiper>
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide">
                <div class="section-announcement-bar__content" {{ block.shopify_attributes }}>
                  <p class="section-announcement-bar__text">{{ block.settings.text }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <button class="section-announcement-bar__btn section-announcement-bar__btn--next" data-next-announcement></button>
      </div>
    {% endif %}
  {% endif %}
</div>

{% schema %}
  {
    "name": "Barre d'annonce",
    "settings": [
      {
        "type": "color",
        "id": "bg_color",
        "label": "Couleur de fond",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Couleur du texte",
        "default": "#FFFFFF"
      },
      {
        "type": "range",
        "id": "margin_top",
        "label": "Marge top",
        "default": 0,
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "label": "Marge bottom",
        "default": 0,
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px"
      }
    ],
    "blocks": [
      {
        "type": "announcement",
        "name": "Annonce",
        "settings": [
          {
            "type": "richtext",
            "id": "text",
            "label": "Texte",
            "default": "<p>Livraison gratuite à partir de 70€</p>"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Barre d'annonce",
        "blocks": [
          {
            "type": "announcement"
          }
        ]
      }
    ]
  }
{% endschema %}