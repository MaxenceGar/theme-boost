<section class="{{ section.settings.padding_mobile }}">
  <div class="page-width">
    <h2 class="text-[30px]! lg:text-[30px]! font-heading tracking-[-0.2px] text-left mb-6!">
      {{ section.settings.title }}
    </h2>

    <!-- Tab buttons -->
    <div class="flex gap-2! border-b border-black/10 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {% for block in section.blocks %}
        <button
          class="tabs__btn whitespace-nowrap! px-6 py-3 text-[14px]! font-bold! uppercase tracking-[0.8px] border-b-2 transition-all duration-300 cursor-pointer
            {% if forloop.first %}border-black text-black{% else %}border-transparent text-black/40 hover:text-black/70{% endif %}"
          data-tab-index="{{ forloop.index0 }}"
          data-section-id="{{ section.id }}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.tab_title }}
        </button>
      {% endfor %}
    </div>

    <!-- Tab panels -->
    {% for block in section.blocks %}
      <div
        class="tabs__panel grid! grid-cols-1! md:grid-cols-2! gap-10! items-center! pt-[24px]!
          {% if forloop.first %}block!{% else %}hidden!{% endif %}"
        data-tab-panel="{{ forloop.index0 }}"
        data-section-id="{{ section.id }}"
      >
        <div class="rounded-lg overflow-hidden!">
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 1000 }}"
              alt="{{ block.settings.tab_title | escape }}"
              class="w-full! object-cover! rounded-lg {{ section.settings.aspect_ratio }}"
              loading="lazy"
            >
          {% else %}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <div class="flex! flex-col! gap-4!">
          <h3 class="text-[24px] font-bold! tracking-[-0.2px]">{{ block.settings.heading }}</h3>
          <div class="text-[14px]! text-black/80 leading-[170%]">{{ block.settings.text }}</div>
          {% if block.settings.btn_label != blank %}
            <a
              href="{{ block.settings.btn_link }}"
              class="inline-block! w-fit mt-2! px-6 py-3 bg-black text-white! text-[13px]! font-bold! uppercase tracking-[0.8px] rounded-md! transition-all duration-300 hover:bg-black/80"
            >
              {{ block.settings.btn_label }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section.id }}';
    const buttons = document.querySelectorAll(`.tabs__btn[data-section-id="${sectionId}"]`);
    const panels = document.querySelectorAll(`.tabs__panel[data-section-id="${sectionId}"]`);

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        const index = btn.dataset.tabIndex;

        buttons.forEach(function (b) {
          b.classList.remove('border-black', 'text-black');
          b.classList.add('border-transparent', 'text-black/40');
        });
        btn.classList.remove('border-transparent', 'text-black/40');
        btn.classList.add('border-black', 'text-black');

        panels.forEach(function (p) {
          p.classList.remove('block!');
          p.classList.add('hidden!');
        });
        var active = document.querySelector(`.tabs__panel[data-tab-panel="${index}"][data-section-id="${sectionId}"]`);
        active.classList.remove('hidden!');
        active.classList.add('block!');
      });
    });
  });
</script>

{% schema %}
  {
    "name": "Tabs",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Titre de la section",
        "default": "Nos engagements"
      },
      {
        "type": "select",
        "id": "padding_mobile",
        "label": "Padding",
        "options": [
          {
            "value": "pt-[38px]! md:py-[32px]!",
            "label": "Padding en haut"
          },
          {
            "value": "pb-[38px]! md:py-[32px]!",
            "label": "Padding en bas"
          },
          {
            "value": "py-[38px]! md:py-[32px]!",
            "label": "Padding en haut et en bas"
          }
        ],
        "default": "py-[38px]! md:py-[32px]!"
      },
      {
        "type": "select",
        "id": "aspect_ratio",
        "label": "Ratio de l'image",
        "options": [
          {
            "value": "aspect-square",
            "label": "Carré"
          },
          {
            "value": "aspect-video",
            "label": "Vidéo (16/9)"
          },
          {
            "value": "aspect-3/2",
            "label": "3/2"
          }
        ],
        "default": "aspect-3/2"
      }
    ],
    "blocks": [
      {
        "type": "tab",
        "name": "Tab",
        "settings": [
          {
            "type": "text",
            "id": "tab_title",
            "label": "Titre de l'onglet",
            "default": "Onglet"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Titre du contenu",
            "default": "Titre du contenu"
          },
          {
            "type": "richtext",
            "id": "text",
            "label": "Texte",
            "default": "<p>Décrivez le contenu de cet onglet ici.</p>"
          },
          {
            "type": "text",
            "id": "btn_label",
            "label": "Texte du bouton"
          },
          {
            "type": "url",
            "id": "btn_link",
            "label": "Lien du bouton"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Tabs",
        "category": "Maxence",
        "blocks": [
          {
            "type": "tab",
            "settings": {
              "tab_title": "Fabrication",
              "heading": "Fait main au Québec",
              "text": "<p>Chaque pièce est façonnée à la main dans notre atelier.</p>"
            }
          },
          {
            "type": "tab",
            "settings": {
              "tab_title": "Matériaux",
              "heading": "Des matériaux naturels",
              "text": "<p>Nous utilisons des argiles et émaux naturels de haute qualité.</p>"
            }
          },
          {
            "type": "tab",
            "settings": {
              "tab_title": "Livraison",
              "heading": "Livraison soignée",
              "text": "<p>Chaque commande est emballée avec soin pour une livraison en toute sécurité.</p>"
            }
          }
        ]
      }
    ]
  }
{% endschema %}
