<div>
  <div class="relative w-full h-[350px] md:h-full">
    {%- liquid
      assign fetchpriority = 'low'
      assign loading = 'lazy'
      assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
      assign image_width = section.settings.image.width
      assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
    -%}
    {{
      section.settings.image | image_url: width: 2500 | image_tag: loading: loading, fetchpriority: fetchpriority, width: image_width, height: image_height, class: image_class, widths: widths, sizes: '100vw'
    }}
  </div>
</div>

{% schema %}
  {
    "name": "Hero Image",
    "tag": "section",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }
    ],
    "presets": [
      {
        "name": "Hero Image"
      }
    ]
  }
{% endschema %}