{{ 'section-gauche-droite.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign img_fit = 'cover'
  if section.settings.image_object_fit == 'object-contain'
    assign img_fit = 'contain'
  endif

  assign grid_class = 'sgd__grid'
  if section.settings.image_position == 'right'
    assign grid_class = 'sgd__grid sgd__grid--image-right'
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.margin_top }}px;
    padding-bottom: {{ section.settings.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }}
  .sgd {
    --sgd-text-align: {{ section.settings.alignment }};
    --sgd-text-align-mobile: {{ section.settings.text-align-mobile }};
  }
  #shopify-section-{{ section.id }}
  .sgd__grid {
    background-color: {{ section.settings.background_color }};
  }
  #shopify-section-{{ section.id }}
  .sgd__image-col {
    background-color: {{ section.settings.background_color_image }};
    --sgd-img-fit: {{ img_fit }};
  }
{%- endstyle -%}

<div class="sgd{%- if section.settings.enable_page_width %} page-width{% endif -%}" {{ section.shopify_attributes }}>
  <div class="{{ grid_class }}">

    <!-- Image -->
    <div class="sgd__image-col">
      {%- liquid
        assign fetchpriority = 'low'
        assign loading = 'lazy'
        assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
        assign image_width = section.settings.image.width
        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      -%}
      {% if section.settings.image %}
        {{
          section.settings.image | image_url: width: 2500 | image_tag: loading: loading, fetchpriority: fetchpriority, width: image_width, height: image_height, class: 'sgd__image', widths: widths, sizes: '(min-width: 750px) 50vw, 100vw'
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'sgd__image' }}
      {% endif %}
    </div>

    <!-- Content -->
    <div class="sgd__content-col">
      <div>
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'subtitle' %}
              <p
                class="sgd__subtitle"
                style="color: {{ block.settings.color }};"
                {{ block.shopify_attributes }}>
                {{ block.settings.subtitle }}
              </p>

            {% when 'title' %}
              <{{ block.settings.div | downcase }}
                                class="sgd__title"
                                style="color: {{ block.settings.color }};"
                                {{ block.shopify_attributes }}>
                {{ block.settings.title }}
                </{{ block.settings.div | downcase }}>

              {% when 'description' %}
                <div
                  class="sgd__description"
                  style="{% if block.settings.use_custom_color %}--typo-p--color: {{ block.settings.custom_color }};{% endif %} font-size: {{ block.settings.font_size_p }}px;"
                  {{ block.shopify_attributes }}>
                  {{ block.settings.description }}
                </div>

              {% when 'button' %}
                {% if block.settings.button_label != blank and block.settings.button_url != blank %}
                  <div class="sgd__button-wrapper" {{ block.shopify_attributes }}>
                    <a href="{{ block.settings.button_url }}" class="btn {{ block.settings.button_style }}">
                      {% if block.settings.button_label_mobile != blank %}
                        <span class="sgd__button-label--desktop">{{ block.settings.button_label }}</span>
                        <span class="sgd__button-label--mobile">{{ block.settings.button_label_mobile }}</span>
                      {% else %}
                        {{- block.settings.button_label -}}
                      {% endif %}
                    </a>
                  </div>
                {% endif %}

            {% endcase %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>

  {% schema %}
    {
      "name": "Section Gauche Droite",
      "class": "section-gauche-droite",
      "settings": [
        {
          "type": "checkbox",
          "id": "enable_page_width",
