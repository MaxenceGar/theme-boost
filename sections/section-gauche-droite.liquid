          "id": "background_color",
          "label": "Couleur de fond",
          "default": "#FBF8F5"
        },
        {
          "type": "color",
          "id": "background_color_image",
          "label": "Couleur de fond image",
          "default": "#FBF8F5"
        },
        {
          "type": "header",
