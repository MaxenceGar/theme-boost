              "value": "left",
              "label": "Gauche"
            },
            {
              "value": "center",
              "label": "Centre"
            },
            {
              "value": "right",
              "label": "Droite"
            }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignement sur ordinateur",
