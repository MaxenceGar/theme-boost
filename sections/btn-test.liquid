{{ 'section-btn-test.css' | asset_url | stylesheet_tag }}

{% capture stars %}
    <svg width="14px" height="14px" class="star reviews-summary-star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M11.5245 3.46353C11.6741 3.00287 12.3259 3.00287 12.4755 3.46353L14.1329 8.56434C14.1998 8.77035 14.3918 8.90983 14.6084 8.90983H19.9717C20.4561 8.90983 20.6575 9.52964 20.2656 9.81434L15.9266 12.9668C15.7514 13.0941 15.678 13.3198 15.745 13.5258L17.4023 18.6266C17.552 19.0873 17.0248 19.4704 16.6329 19.1857L12.2939 16.0332C12.1186 15.9059 11.8814 15.9059 11.7061 16.0332L7.3671 19.1857C6.97524 19.4704 6.448 19.0873 6.59768 18.6266L8.25503 13.5258C8.32197 13.3198 8.24864 13.0941 8.07339 12.9668L3.73438 9.81434C3.34253 9.52964 3.54392 8.90983 4.02828 8.90983H9.39159C9.6082 8.90983 9.80018 8.77035 9.86712 8.56434L11.5245 3.46353Z" fill="black"></path>
            </svg>
{% endcapture %}
{%- style -%}
  .btn-test {
    background-color: {{ settings.btn_test_bg_color }};
    color: {{ settings.btn_test_text_color }};
    border-radius: var(--rounded--size);
    padding: {{ settings.btn_test_padding }}px;
    font-size: {{ settings.btn_test_font_size }}px;
  }

  {% if settings.btn_test_hover_enabled %}
    {% if settings.btn_test_hover_effect == 'opacity' %}
      .btn-test:hover {
        opacity: {{ settings.btn_test_hover_opacity | divided_by: 100.0 }};
      }
    {% elsif settings.btn_test_hover_effect == 'background' %}
    .btn-test:hover {
      background-color: {{ settings.btn_test_hover_bg_color }};
    }
  {% elsif settings.btn_test_hover_effect == 'scale' %}
  .btn-test:hover {
    transform: scale({{ settings.btn_test_hover_scale | divided_by: 100.0 }});
  }
{% endif %}
{% endif %}
{%- endstyle -%}

<div class="btn-test-section">
  <button class="btn btn-test">
    {{ settings.btn_test_text }}
  </button>
</div>

<div class="container-review">
  <div class="review_container">
    <span class="rating-stars-container">
      <div class="rating-stars">

        {{ stars }}
        {{ stars }}
        {{ stars }}
        {{ stars }}
        {{ stars }}

      </div>
    </span>
    <div>
      <p class="rating-text">Rated 4.8/5 based on +10,839 Total Ratings</p>
    </div>
  </div>
  <p class="rating-text">See what our customers are saying about our products</p>
</div>

<style>

  .container-review {
    padding-top: 50px;
    padding-bottom: 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
    background-color: #fffdf5;
  }

  .rating-text {
    font-size: 13px !important;
    letter-spacing: -0.6px;
    color: black;
    text-align: center;
  }

  .review_container {
    border-radius: 999px;
    display: flex;
    flex-direction: row;
    align-items: center;
    border: dashed black 1px;
    padding: 5px 10px;
    gap: 1rem;
    width: fit-content;
  }

  .rating-stars {
    color: red;
    display: flex;
    gap: -100px;
  }
</style>

{% schema %}
