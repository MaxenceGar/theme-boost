{% stylesheet %}
  .design-system {
    padding: 40px 20px;
  }

  .design-system__section {
    margin-bottom: 60px;
  }

  .design-system__title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 30px;
    border-bottom: 2px solid #000;
    padding-bottom: 15px;
  }

  .design-system__subtitle {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 15px;
    margin-top: 25px;
  }

  .design-system__grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 20px;
  }

  .design-system__item {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
{% endstylesheet %}

<div class="design-system">
  <!-- Typographies -->
  <div class="design-system__section">
    <h1 class="design-system__title">Typographies</h1>

    <div class="design-system__subtitle">Headings</div>
    <div class="design-system__grid">
      <div class="design-system__item">
        <h1>H1 - Heading 1</h1>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_h1_size }}px</span>
      </div>
      <div class="design-system__item">
        <h2>H2 - Heading 2</h2>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_h2_size }}px</span>
      </div>
      <div class="design-system__item">
        <h3>H3 - Heading 3</h3>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_h3_size }}px</span>
      </div>
      <div class="design-system__item">
        <h4>H4 - Heading 4</h4>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_h4_size }}px</span>
      </div>
      <div class="design-system__item">
        <h5>H5 - Heading 5</h5>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_h5_size }}px</span>
      </div>
      <div class="design-system__item">
        <h6>H6 - Heading 6</h6>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_h6_size }}px</span>
      </div>
    </div>

    <div class="design-system__subtitle">Body Text</div>
    <div class="design-system__item">
      <p>This is a paragraph. Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      <span style="font-size: 0.75rem; color: #666;">{{ settings.typo_p_size }}px</span>
    </div>
  </div>

  <!-- Buttons -->
  <div class="design-system__section">
    <h2 class="design-system__title">Buttons</h2>

    <div class="design-system__grid">
      <div class="design-system__item">
        <button class="btn btn-primaire">Primary Button</button>
      </div>
      <div class="design-system__item">
        <button class="btn btn-secondaire">Secondary Button</button>
      </div>
      <div class="design-system__item">
        <button class="btn btn-tertiaire">Tertiary Button</button>
      </div>
    </div>

    <div style="margin-top: 30px;">
      <div class="design-system__subtitle">Button Sizes</div>
      <div class="design-system__grid">
        <div class="design-system__item">
          <button class="btn btn-primaire" style="padding: 8px 16px; font-size: 0.875rem;">Small</button>
        </div>
        <div class="design-system__item">
          <button class="btn btn-primaire">Default</button>
        </div>
        <div class="design-system__item">
          <button class="btn btn-primaire" style="padding: 16px 40px; font-size: 1.125rem;">Large</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Colors -->
  <div class="design-system__section">
    <h2 class="design-system__title">Colors</h2>

    <div class="design-system__grid">
      <div class="design-system__item">
        <div style="width: 100%; height: 100px; background-color: var(--color-bg-primaire); border: 1px solid #ddd;">Primary BG</div>
        <span style="font-weight: 600;">Primary BG</span>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.bg_color_primaire }}</span>
      </div>
      <div class="design-system__item">
        <div style="width: 100%; height: 100px; background-color: var(--color-bg-secondaire); border: 1px solid #ddd;">Secondary BG</div>
        <span style="font-weight: 600;">Secondary BG</span>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.bg_color_secondaire }}</span>
      </div>
      <div class="design-system__item">
        <div style="width: 100%; height: 100px; background-color: var(--color-bg-secondaire-hover); border: 1px solid #ddd;">Secondary Hover</div>
        <span style="font-weight: 600;">Secondary Hover</span>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.bg_color_secondaire_hover }}</span>
      </div>
    </div>
  </div>

  <!-- Border Radius -->
  <div class="design-system__section">
    <h2 class="design-system__title">Border Radius</h2>

    <div class="design-system__grid">
      <div class="design-system__item">
        <div style="width: 100%; height: 100px; background-color: #000; border-radius: var(--rounded--size);">p</div>
        <span style="font-weight: 600;">Rounded Size</span>
        <span style="font-size: 0.75rem; color: #666;">{{ settings.border_radius }}</span>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Design System",
    "settings": [],
    "presets": [
      {
        "name": "Design System"
      }
    ]
  }
{% endschema %}