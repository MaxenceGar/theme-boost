{{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign preview_mode = section.settings.preview_mode
  assign preview_product = section.settings.preview_product
  assign cart_has_items = false
  if cart != empty or preview_mode and preview_product != blank
    assign cart_has_items = true
  endif
-%}

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer
  class="drawer{% unless cart_has_items %} is-empty{% endunless %}"
  {% if preview_mode and preview_product != blank %}
  data-preview-mode{% endif %}>
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay bg-[#d9d9d999]!"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1">

      {%- comment -%} État vide {%- endcomment -%}
      {%- unless cart_has_items -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}">
                <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>
            </div>
          </div>
        </div>
      {%- endunless -%}

      {%- comment -%} Header {%- endcomment -%}
      <div class="drawer__header mx-10">
        <h2 class="drawer__heading h4">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}">
          <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      <div class="drawer__header justify-center! bg-black text-white">
        <p class="text-center!">En ce moment 2 Achetées = 2 Offertes</p>
      </div>

      {%- comment -%} Blocks (timer, palier, texte) {%- endcomment -%}
      {% for block in section.blocks %}
        {% case block.type %}

          {% when 'timer' %}
            {% if cart_has_items %}
              <div class="bg-gray-200! text-center py-8 text-black!" {{ block.shopify_attributes }}>
                Vos produits sont réservés<br>pendant
                <span id="cart-timer" class="font-bold!">10:00</span>
                minutes !
              </div>
            {% endif %}

          {% when 'text' %}
            <div class="bg-gray-200! text-center text-black! text-[14px]" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {% when 'palier' %}
            {% render 'palier-cart-drawer'
              , block: block %}
        {% endcase %}
      {% endfor %}

      {%- comment -%} Cart items {%- endcomment -%}
      <cart-drawer-items
        {% unless cart_has_items %}
        class="is-empty"
        {% endunless %}>
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post">
          <div id="CartDrawer-CartItems" class="m-4 drawer__contents js-contents">
            {%- if cart_has_items -%}
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <thead role="rowgroup">
                    <tr role="row">
                      <th id="CartDrawer-ColumnProductImage" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span>
                      </th>
                      <th
                        id="CartDrawer-ColumnProduct"
                        class="caption-with-letter-spacing"
                        scope="col"
                        role="columnheader">
                        {{ 'sections.cart.headings.product' | t }}
                      </th>
                      <th
                        id="CartDrawer-ColumnTotal"
                        class="right caption-with-letter-spacing"
                        scope="col"
                        role="columnheader">
                        {{ 'sections.cart.headings.total' | t }}
                      </th>
                      <th id="CartDrawer-ColumnQuantity" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span>
                      </th>
                    </tr>
                  </thead>

                  <tbody role="rowgroup">
                    {%- comment -%} Preview product {%- endcomment -%}
                    {%- if preview_mode and preview_product != blank and cart == empty -%}
                      {%- assign pv = preview_product.selected_or_first_available_variant -%}
                      {%- assign pv_img = pv.image | default: preview_product.featured_image -%}
                      {%- if settings.currency_code_enabled -%}
                        {%- assign pv_price = pv.price | money_with_currency -%}
                      {%- else -%}
                        {%- assign pv_price = pv.price | money -%}
                      {%- endif -%}
                      <tr
                        id="CartDrawer-Item-preview"
                        class="cart-item"
                        role="row">
                        <td
                          class="cart-item__media"
                          role="cell"
                          headers="CartDrawer-ColumnProductImage">
                          {% if pv_img %}
                            <a
                              href="{{ preview_product.url }}"
                              class="cart-item__link"
                              tabindex="-1"
                              aria-hidden="true"></a>
                            <img
                              class="cart-item__image"
                              src="{{ pv_img | image_url: width: 300 }}"
                              alt="{{ pv_img.alt | escape }}"
                              loading="lazy"
                              width="150"
                              height="{{ 150 | divided_by: pv_img.aspect_ratio | ceil }}">
                          {% endif %}
                        </td>
                        <td
                          class="cart-item__details"
                          role="cell"
                          headers="CartDrawer-ColumnProduct">
                          <a href="{{ preview_product.url }}" class="cart-item__name p break">{{ preview_product.title | escape }}</a>
                          {%- if preview_product.has_only_default_variant == false -%}
                            <dl>
                              {%- for option in pv.options -%}
                                <div class="product-option">
                                  <dt>{{ preview_product.options[forloop.index0] }}:</dt>
                                  <dd>{{ option }}</dd>
                                </div>
                              {%- endfor -%}
                            </dl>
                          {%- endif -%}
                        </td>
                        <td
                          class="cart-item__totals right"
                          role="cell"
                          headers="CartDrawer-ColumnTotal">
                          <div class="cart-item__price-wrapper">
                            <span class="price price--end">{{ pv_price }}</span>
                          </div>
                        </td>
                        <td
                          class="cart-item__quantity"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity">
                          <div class="cart-item__quantity-wrapper quantity-popover-wrapper rounded-full">
                            <div class="quantity-popover-container">
                              <quantity-input class="quantity cart-quantity rounded-full!">
                                <button
                                  class="quantity__button"
                                  name="minus"
                                  type="button">
                                  <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                                </button>
                                <input
                                  class="quantity__input"
                                  type="number"
                                  value="1"
                                  min="0"
                                  step="1">
                                <button
                                  class="quantity__button"
                                  name="plus"
                                  type="button">
                                  <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                                </button>
                              </quantity-input>
                            </div>
                          </div>
                        </td>
                      </tr>
                    {%- endif -%}

                    {%- comment -%} Real cart items {%- endcomment -%}
                    {%- for item in cart.items -%}
                      <tr
                        id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                        class="cart-item"
                        role="row">
                        <td
                          class="cart-item__media"
                          role="cell"
                          headers="CartDrawer-ColumnProductImage">
                          {% if item.image %}
                            <a
                              href="{{ item.url }}"
                              class="cart-item__link"
                              tabindex="-1"
                              aria-hidden="true"></a>
                            <img
                              class="cart-item__image"
                              src="{{ item.image | image_url: width: 300 }}"
                              alt="{{ item.image.alt | escape }}"
                              loading="lazy"
                              width="150"
                              height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}">
                          {% endif %}
                        </td>

                        <td
                          class="cart-item__details"
                          role="cell"
                          headers="CartDrawer-ColumnProduct">
                          <a href="{{ item.url }}" class="cart-item__name h4 break">{{ item.product.title | escape }}</a>

                          {%- if item.original_price != item.final_price -%}
                            <div class="cart-item__discounted-prices">
                              <s class="cart-item__old-price product-option">{{ item.original_price | money }}</s>
                              <strong class="cart-item__final-price product-option">{{ item.final_price | money }}</strong>
                            </div>
                          {%- else -%}
                            <div class="product-option">{{ item.original_price | money }}</div>
                          {%- endif -%}

                          {%- if item.product.has_only_default_variant == false -%}
                            <dl>
                              {%- for option in item.options_with_values -%}
                                <div class="product-option">
                                  <dt>{{ option.name }}:</dt>
                                  <dd>{{ option.value }}</dd>
                                </div>
                              {%- endfor -%}
                            </dl>
                          {%- endif -%}

                          {%- if item.line_level_discount_allocations.size > 0 -%}
                            <ul
                              class="discounts list-unstyled"
                              role="list"
                              aria-label="{{ 'customer.order.discount' | t }}">
                              {%- for discount in item.line_level_discount_allocations -%}
                                <li class="discounts__discount">
                                  {{- 'icon-discount.svg' | inline_asset_content -}}
                                  {{ discount.discount_application.title }}
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </td>

                        <td
                          class="cart-item__totals right"
                          role="cell"
                          headers="CartDrawer-ColumnTotal">
                          {%- render 'loading-spinner' -%}
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s>
                              <span class="price price--end">{{ item.final_line_price | money }}</span>
                            {%- else -%}
                              <span class="price price--end">{{ item.original_line_price | money }}</span>
                            {%- endif -%}
                          </div>
                        </td>

                        <td
                          class="cart-item__quantity"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity">
                          <div class="cart-item__quantity-wrapper quantity-popover-wrapper rounded-full">
                            <div class="quantity-popover-container">
                              <quantity-input class="quantity cart-quantity rounded-full!">
                                <button
                                  class="quantity__button"
                                  name="minus"
                                  type="button">
                                  <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                                </button>
                                <input
                                  class="quantity__input"
                                  type="number"
                                  data-quantity-variant-id="{{ item.variant.id }}"
                                  name="updates[]"
                                  value="{{ item.quantity }}"
                                  {% # theme-check-disable %}
                                  data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                  min="0"
                                  data-min="{{ item.variant.quantity_rule.min }}"
                                  {% if item.variant.quantity_rule.max != null %}
                                  max="{{ item.variant.quantity_rule.max }}"
                                  {% endif %}
                                  step="{{ item.variant.quantity_rule.increment }}"
                                  {% # theme-check-enable %}
                                  aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                  id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                  data-index="{{ item.index | plus: 1 }}">
                                <button
                                  class="quantity__button"
                                  name="plus"
                                  type="button">
                                  <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                                </button>
                              </quantity-input>
                            </div>
                            <cart-remove-button id="CartDrawer-Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                              <button
                                type="button"
                                class="button button--tertiary cart-remove-button"
                                aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                                data-variant-id="{{ item.variant.id }}">
                                <span class="svg-wrapper">{{- 'icon-remove.svg' | inline_asset_content -}}</span>
                              </button>
                            </cart-remove-button>
                          </div>
                          <div
                            id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                            class="cart-item__error"
                            role="alert">
                            <small class="cart-item__error-text"></small>
                            <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                          </div>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p
              id="CartDrawer-LiveRegionText"
              class="visually-hidden"
              role="status"></p>
            <p
              id="CartDrawer-LineItemStatus"
              class="visually-hidden"
              aria-hidden="true"
              role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {%- comment -%} Footer {%- endcomment -%}
      <div class="drawer__footer m-4">
        <div class="cart-drawer__footer">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'upsell-product-page' -%}
                {%- render 'upsell-product-page'
                  , block: block -%}
            {%- endcase -%}
          {%- endfor -%}
          {%- if section.settings.enable_reassurance -%}
            {% render 'footer-rassurance' %}
          {%- endif -%}
          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <ul
              class="discounts list-unstyled"
              role="list"
              aria-label="{{ 'customer.order.discount' | t }}">
              {%- for discount in cart.cart_level_discount_applications -%}
                <li class="discounts__discount discounts__discount--end">
                  {{- 'icon-discount.svg' | inline_asset_content -}}
                  {{ discount.title | escape }}
                  (-{{ discount.total_allocated_amount | money }})
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- liquid
            if preview_mode and preview_product != blank and cart == empty
              assign display_total = pv.price | money_with_currency
            else
              assign display_total = cart.total_price | money_with_currency
            endif
          -%}
          <div class="totals" role="status">
            <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2>
            <p class="totals__total-value">{{ display_total }}</p>
          </div>
        </div>

        <div class="cart__ctas mt-8">
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button button bg-black! text-white! border-none!"
            name="checkout"
            form="CartDrawer-Form"
            {% unless cart_has_items %}
            disabled{% endunless %}>
            {{ 'sections.cart.checkout' | t }}
          </button>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

{%- if preview_mode and preview_product != blank -%}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const drawer = document.querySelector('cart-drawer[data-preview-mode]');
      if (drawer) setTimeout(function() { drawer.open(); }, 500);
    });
  </script>
{%- endif -%}

{% schema %}
  {
    "name": "Cart Drawer",
    "limit": 1,
    "settings": [
      {
        "type": "header",
        "content": "Mode Preview (dev)"
      },
      {
        "type": "checkbox",
        "id": "preview_mode",
        "label": "Activer le mode preview",
        "default": false,
        "info": "Ouvre le cart drawer automatiquement avec un produit fictif. Désactiver avant de publier."
      },
      {
        "type": "product",
        "id": "preview_product",
        "label": "Produit à afficher"
      },
      {
        "type": "checkbox",
        "id": "enable_reassurance",
        "label": "Afficher le block de reassurance"
      }
    ],
    "blocks": [
      {
        "type": "timer",
        "name": "Timer réservation",
        "limit": 1,
        "settings": []
      },
      {
        "type": "upsell-product-page",
        "name": "UpSell",
        "limit": 1,
        "settings": [
          {
            "type": "header",
            "content": "Upsell Product Page"
          },
          {
            "type": "text",
            "id": "title",
            "default": "Vous aimerez aussi",
            "label": "Titre"
          },
          {
            "type": "product",
            "id": "product_1",
            "label": "Produit 1"
          },
          {
            "type": "product",
            "id": "product_2",
            "label": "Produit 2"
          },
          {
            "type": "product",
            "id": "product_3",
            "label": "Produit 3"
          },
          {
            "type": "product",
            "id": "product_4",
            "label": "Produit 4"
          }
        ]
      },
      {
        "type": "text",
        "name": "Texte",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "default": "Texte",
            "id": "text",
            "label": "Texte"
          }
        ]
      },
      {
        "type": "palier",
        "name": "Paliers avantages",
        "limit": 1,
        "settings": [
          {
            "type": "color",
            "id": "bar_color",
            "label": "Couleur de la barre",
            "default": "#000000"
          },
          {
            "type": "header",
            "content": "Palier 1"
          },
          {
            "type": "number",
            "id": "palier_1_amount",
            "label": "Montant (€)",
            "default": 30
          },
          {
            "type": "text",
            "id": "palier_1_text",
            "label": "Texte",
            "default": "Livraison offerte"
          },
          {
            "type": "image_picker",
            "id": "palier_1_icon",
            "label": "Icône (optionnel)"
          },
          {
            "type": "header",
            "content": "Palier 2"
          },
          {
            "type": "number",
            "id": "palier_2_amount",
            "label": "Montant (€)",
            "default": 60
          },
          {
            "type": "text",
            "id": "palier_2_text",
            "label": "Texte",
            "default": "Cadeau offert"
          },
          {
            "type": "image_picker",
            "id": "palier_2_icon",
            "label": "Icône (optionnel)"
          }
        ]
      }
    ],
    "enabled_on": {
      "groups": ["header"]
    }
  }
{% endschema %}