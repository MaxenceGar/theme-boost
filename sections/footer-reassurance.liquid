<section class="{{ section.settings.padding_mobile }}" style="background-color: {{ section.settings.bg_color }}">
  <div class="page-width grid! grid-cols-2! md:grid-cols-{{ section.blocks.size }}! gap-6! md:gap-4!">
    {% for block in section.blocks %}
      <div class="flex! flex-col! items-center! text-center! gap-2! text-black!" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          <div class="w-15! h-15! shrink-0!">
            {{ block.settings.icon | image_url: width: 80 | image_tag: class: 'w-full! h-full! object-contain!', loading: 'lazy' }}
          </div>
        {% endif %}
        {% if block.settings.title != blank %}
          <p class="text-[18px]! font-bold! leading-tight! m-0!">{{ block.settings.title }}</p>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="text-[14px]! leading-tight! m-0! opacity-70!">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
  {
    "name": "Reassurance Footer",
    "settings": [
      {
        "type": "color",
        "default": "#FFFFFF",
        "id": "bg_color",
        "label": "Couleur de fond"
      },
      {
        "type": "select",
        "id": "padding_mobile",
        "label": "Padding sur mobile",
        "options": [
          {
            "value": "pt-[38px]! md:py-[32px]!",
            "label": "Padding en haut"
          },
          {
            "value": "pb-[38px]! md:py-[32px]!",
            "label": "Padding en bas"
          },
          {
            "value": "py-[38px]! md:py-[32px]!",
            "label": "Padding en haut et en bas"
          }
        ],
        "default": "py-[38px]! md:py-[32px]!"
      }
    ],
    "blocks": [
      {
        "type": "feature",
        "name": "Feature",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "Icône"
          },
          {
            "type": "text",
            "id": "title",
            "default": "Titre",
            "label": "Titre"
          },
          {
            "type": "text",
            "id": "subtitle",
            "default": "Sous-titre",
            "label": "Sous-Titre"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Reassurance Footer",
        "blocks": [
          {
            "type": "feature"
          },
          {
            "type": "feature"
          },
          {
            "type": "feature"
          },
          {
            "type": "feature"
          }
        ]
      }
    ]
  }
{% endschema %}