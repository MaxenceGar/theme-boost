<section class="py-16 page-width">
  {% if section.settings.title != blank %}
    <h2 class="text-[32px] lg:text-[48px] font-bold text-center mb-12 text-black!">
      {{ section.settings.title }}
    </h2>
  {% endif %}

  <div class="flex flex-col">
    {% for block in section.blocks %}
      {% if block.type == 'faq_item' %}
        <div class="border-b border-black/20" {{ block.shopify_attributes }}>
          <input
            type="checkbox"
            id="faq-{{ block.id }}"
            class="peer sr-only">
          <label for="faq-{{ block.id }}" class="flex items-center justify-between py-5 cursor-pointer select-none text-center!">
            <span class="text-7xl font-bold! text-black! text-center!">
              {{ block.settings.question }}
            </span>
            <span class="text-2xl transition-transform duration-300 peer-checked:rotate-45">+</span>
          </label>
          <div class="grid grid-rows-[0fr] peer-checked:grid-rows-[1fr] transition-all duration-300 overflow-hidden">
            <div class="min-h-0">
              <div class="pb-5 text-[14px] lg:text-[16px] text-black/80">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
  {
    "name": "FAQ",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Titre",
        "default": "Questions fréquentes"
      }
    ],
    "blocks": [
      {
        "type": "faq_item",
        "name": "Question",
        "settings": [
          {
            "type": "text",
            "id": "question",
            "label": "Question",
            "default": "Votre question ici ?"
          },
          {
            "type": "richtext",
            "id": "answer",
            "label": "Réponse",
            "default": "<p>Votre réponse ici.</p>"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "FAQ",
        "blocks": [
          {
            "type": "faq_item",
            "settings": {
              "question": "Qu'est-ce que le sébum ?",
              "answer": "<p>Le sébum est un mélange complexe de lipides sécrété par les glandes sébacées. Lorsqu'il n'est pas en excès, il joue un rôle clé en formant une barrière protectrice.</p>"
            }
          },
          {
            "type": "faq_item",
            "settings": {
              "question": "Qu'est-ce qui cause une surproduction de sébum ?",
              "answer": "<p>Les causes peuvent être internes liées à la génétique ou aux hormones ; mais aussi externes liées à l'environnement, l'alimentation ou le style de vie.</p>"
            }
          },
          {
            "type": "faq_item",
            "settings": {
              "question": "Quels produits cosmétiques éviter ?",
              "answer": "<p>Il est nécessaire de choisir un produit cosmétique non comédogène. Évitez les huiles minérales, les cires lourdes et la lanoline.</p>"
            }
          }
        ]
      }
    ]
  }
{% endschema %}