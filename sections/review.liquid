{{ 'section-review.css' | asset_url | stylesheet_tag }}

  <div class="container-review page-width" style="margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;">

  <!-- Header avec note globale -->
  <div class="review_container">
    <span class="rating-stars-container">
      <div class="rating-stars">
        {% for i in (1..5) %}
          <span class="star{% if i <= section.settings.global_rating %} active{% endif %}">★</span>
        {% endfor %}
      </div>
    </span>
    <div>
      <p class="rating-text">{{ section.settings.rating_text }}</p>
    </div>
  </div>

  {% if section.settings.subtitle != blank %}
    <p class="review-subtitle">{{ section.settings.subtitle }}</p>
  {% endif %}

  <!-- Reviews Container -->
  <div class="img_review_container">
    {% for block in section.blocks %}
      {% if block.type == 'review' %}
        <div class="img_review_contain" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              class="img_review"
              src="{{ block.settings.image | image_url: width: 250 }}"
              alt="{{ block.settings.author_name }}">
          {% endif %}

          <!-- Stars et info auteur -->
          <div class="review-header">
            <div class="review-stars">
              {% for i in (1..5) %}
                <span class="star{% if i <= block.settings.rating %} active{% endif %}">★</span>
              {% endfor %}
            </div>
            <div class="author-info">
              <p class="rating-text author-name">{{ block.settings.author_name }}</p>
              <p class="rating-text verified">✓ Verified Buyer</p>
            </div>
          </div>

          <!-- Texte de l’avis -->
          <p class="rating-text review-text">{{ block.settings.review_text }}</p>

          <!-- Produit -->
          {% if block.settings.product != blank %}
            <div class="product-box">
              <p class="rating-text product-name">{{ block.settings.product.title }}</p>
              <p class="rating-text product-price">{{ block.settings.product.price | money }}</p>
              {% if block.settings.purchase_date != blank %}
                <p class="rating-text purchase-date">📅 {{ block.settings.purchase_date }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

</div>

{% schema %}
  {
    "name": "Avis Clients",
    "settings": [
      {
        "type": "header",
        "content": "En-tête"
      },
      {
        "type": "range",
        "id": "global_rating",
        "min": 0,
        "max": 5,
        "step": 1,
        "label": "Note globale (étoiles)",
        "default": 5
      },
      {
        "type": "text",
        "id": "rating_text",
        "label": "Texte de la note",
        "default": "Rated 4.8/5 based on +10,839 Total Ratings"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "Sous-titre",
        "default": "Découvrez ce que nos clients pensent"
      },
      {
        "type": "header",
        "content": "Paramètres"
      },
      {
        "type": "range",
        "id": "margin_top",
        "label": "Marge top",
        "default": 0,
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "label": "Marge bottom",
        "default": 0,
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px"
      }
    ],
    "blocks": [
      {
        "type": "review",
        "name": "Avis",
        "settings": [
          {
            "type": "header",
            "content": "Avis"
          },
          {
            "type": "text",
            "id": "author_name",
            "label": "Prénom du client",
            "default": "Client"
          },
          {
            "type": "range",
            "id": "rating",
            "min": 0,
            "max": 5,
            "step": 1,
            "label": "Nombre d'étoiles",
            "default": 5
          },
          {
            "type": "textarea",
            "id": "review_text",
            "label": "Texte de l'avis",
            "default": "Excellent produit, très satisfait de mon achat!"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Photo du client"
          },
          {
            "type": "header",
            "content": "Produit"
          },
          {
            "type": "product",
            "id": "product",
            "label": "Produit associé"
          },
          {
            "type": "text",
            "id": "purchase_date",
            "label": "Date d'achat",
            "placeholder": "Ex: Acheté en mars 2026"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Avis Clients"
      }
    ]
  }
{% endschema %}