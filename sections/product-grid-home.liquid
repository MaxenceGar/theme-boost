{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_to_show = section.settings.products_to_show
  assign use_swiper = false
  if products_to_show > 5
    assign use_swiper = true
  endif
-%}

{% if use_swiper %}
  {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
{% endif %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-grid-swiper-{{ section.id }}
  .swiper-wrapper {
    align-items: stretch;
  }
  .product-grid-swiper-{{ section.id }}
  .swiper-slide {
    height: auto;
  }

  .product-grid-swiper-{{ section.id }}
  .swiper-button-prev
  , .product-grid-swiper-{{ section.id }}
  .swiper-button-next {
    --swiper-navigation-size: 14px;
    width: 40px;
    height: 40px;
    top: 40%;
    padding: 10px !important;
  }
  .product-grid-swiper-{{ section.id }}.swiper-button-prev:hover,
  .product-grid-swiper-{{ section.id }}.swiper-button-next:hover {
    background-color: #f5f5f5;
    width: 20px;
    height: 20px;
  }
  .product-grid-swiper-{{ section.id }}
  .swiper-button-prev.swiper-button-disabled
  , .product-grid-swiper-{{ section.id }}
  .swiper-button-next.swiper-button-disabled {
    opacity: 0.3;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="page-width">
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="mb-6!">
        {% if section.settings.title != blank %}
          <div class="flex justify-between items-center">
            <h2 class="{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {{ section.settings.title }}
            </h2>
            {% if section.settings.enable_btn %}
              <a href="{{ section.settings.collection.url }}" class="btn {{ section.settings.button_style }} hidden! md:block!">{{ section.settings.text_btn }}</a>
            {% endif %}
          </div>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="mt-1! opacity-70!">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}

      {% if use_swiper %}
        {%- comment -%} Swiper carousel mode (> 5 products) {%- endcomment -%}
        <div class="product-grid-swiper-{{ section.id }} relative! {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <div class="swiper" id="ProductGridSwiper-{{ section.id }}">
            <div class="swiper-wrapper gap-10">
              {%- for product in section.settings.collection.products limit: products_to_show -%}
                <div class="swiper-slide">
                  {% render 'card-product'
                    , card_product: product
                    , media_aspect_ratio: section.settings.image_ratio
                    , show_secondary_image: section.settings.show_secondary_image
                    , show_vendor: section.settings.show_vendor
                    , show_rating: false
                    , lazy_load: true
                    , section_id: section.id
                    , custom_classes: ''
                  %}
                </div>
              {%- endfor -%}
            </div>
            {% if section.settings.enable_btn %}
              <a href="{{ section.settings.collection.url }}" class="flex mt-10! btn {{ section.settings.button_style }} md:hidden! block!">{{ section.settings.text_btn }}</a>
            {% endif %}
            <div class="swiper-button-prev btn btn-primaire"></div>
            <div class="swiper-button-next btn btn-primaire"></div>
          </div>
        </div>

        <script>
          document.addEventListener('DOMContentLoaded', function () {
            new Swiper('#ProductGridSwiper-{{ section.id }}', {
              slidesPerView: 2,
              spaceBetween: 16,
              navigation: {
                prevEl: '.product-grid-swiper-{{ section.id }} .swiper-button-prev',
                nextEl: '.product-grid-swiper-{{ section.id }} .swiper-button-next',
              },
              breakpoints: {
                750: { slidesPerView: 3, spaceBetween: 10 },
                990: { slidesPerView: 4, spaceBetween: 1 },
                1200: { slidesPerView: 5, spaceBetween: 1 },
              },
            });
          });
        </script>

      {% else %}
        {%- comment -%} Grid mode (<= 5 products) {%- endcomment -%}
        <ul class="grid! grid-cols-2! md:grid-cols-3! lg:grid-cols-{{ products_to_show }}! gap-4! md:gap-16! list-none! p-0!" role="list">
          {%- for product in section.settings.collection.products limit: products_to_show -%}
            <li>
              {% render 'card-product'
                , card_product: product
                , media_aspect_ratio: section.settings.image_ratio
                , show_secondary_image: section.settings.show_secondary_image
                , show_vendor: section.settings.show_vendor
                , show_rating: false
                , lazy_load: true
                , section_id: section.id
              %}
            </li>
          {%- endfor -%}
        </ul>
      {% endif %}

    {% else %}
      {%- comment -%} Placeholder when no collection selected {%- endcomment -%}
      <ul class="grid! grid-cols-2! md:grid-cols-4! gap-4! md:gap-6! list-none! p-0!" role="list">
        {%- for i in (1..4) -%}
          <li>
            {%- assign placeholder_image = 'product-apparel-' | append: i -%}
            {% render 'card-product'
              , show_vendor: false
              , media_aspect_ratio: 'square'
              , lazy_load: false
              , placeholder_image: placeholder_image
            %}
          </li>
        {%- endfor -%}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
  {
    "name": "Grille de produits",
    "tag": "section",
    "class": "section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings": [
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      },
      {
        "type": "range",
        "id": "products_to_show",
        "min": 2,
        "max": 25,
        "step": 1,
        "default": 4,
        "label": "Nombre de produits"
      },
      {
        "type": "inline_richtext",
        "id": "title",
        "default": "Nos produits",
        "label": "Titre"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "Sous-titre"
      },
      {
        "type": "checkbox",
        "id": "enable_btn",
        "default": false,
        "label": "Afficher btn VOIR TOUT"
      },
      {
        "type": "select",
        "id": "button_style",
        "label": "Style du bouton",
        "options": [
          {
            "value": "btn-primaire",
            "label": "Primaire"
          },
          {
            "value": "btn-secondaire",
            "label": "Secondaire"
          },
          {
            "value": "btn-tertiaire",
            "label": "Tertiaire"
          }
        ],
        "default": "btn-primaire"
      },
      {
        "type": "text",
        "id": "text_btn",
        "label": "Texte du bouton"
      },
      {
        "type": "header",
        "content": "Carte produit"
      },
      {
        "type": "select",
        "id": "image_ratio",
        "options": [
          {
            "value": "adapt",
            "label": "Adapter à l'image"
          },
          {
            "value": "portrait",
            "label": "Portrait"
          },
          {
            "value": "square",
            "label": "Carré"
          }
        ],
        "default": "adapt",
        "label": "Ratio d'image"
      },
      {
        "type": "checkbox",
        "id": "show_secondary_image",
        "default": false,
        "label": "Afficher l'image secondaire au survol"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "default": false,
        "label": "Afficher le fournisseur"
      },
      {
        "type": "header",
        "content": "Espacement"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Espacement haut",
        "default": 36
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Espacement bas",
        "default": 36
      }
    ],
    "presets": [
      {
        "name": "Grille de produits"
      }
    ]
  }
{% endschema %}