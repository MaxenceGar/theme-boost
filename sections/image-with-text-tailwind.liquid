{{ 'tailwind.css' | asset_url | stylesheet_tag }}

<section class="w-full">
  <div class="bg-[url('https://eu.naak.com/cdn/shop/files/8C6F6766-9837-4867-B5BA-545FE5BD2E11_4500x.jpg')] md:bg-[url('https://eu.naak.com/cdn/shop/files/86E2062A-3D33-43E2-86B6-F5BFBFF403C9_3000x.jpg?v=1768845857')]
           bg-cover bg-right
           flex items-end justify-center md:justify-start md:items-center p-24 min-h-[70vh] md:h-dvh">
    <div class="text-white flex flex-col gap-6 p-1  text-left">
      <h1 class="h1 font-bold! text-white!">Pack Ravito UTMB</h1>
      <p>Teste la nutrition officielle du circuit UTMB® World Series.</p>
      <button class="bg-yellow-300 text-black py-5 px-25 rounded-lg md:self-start md:mx-0 text-[14px] font-bold">
        Découvrir
      </button>
    </div>
  </div>
</section>


{% schema %}
  {
    "name": "Image + Texte",
    "tag": "section",
    "class": "section-image-text-tw",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings": [
      {
        "type": "header",
        "content": "Image"
      },
      {
        "type": "image_picker",
        "id": "image_desktop",
        "label": "Image (desktop)"
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Image (mobile)"
      },
      {
        "type": "header",
        "content": "Mise en page"
      },
      {
        "type": "select",
        "id": "image_position",
        "label": "Position de l'image",
        "options": [
          {
            "value": "left",
            "label": "Gauche"
          },
          {
            "value": "right",
            "label": "Droite"
          }
        ],
        "default": "right"
      }
    ],
    "blocks": [
      {
        "type": "heading",
        "name": "Titre",
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Titre",
            "default": "Notre savoir-faire"
          },
          {
            "type": "select",
            "id": "heading_tag",
            "label": "Balise HTML",
            "options": [
              {
                "value": "h1",
                "label": "H1"
              },
              {
                "value": "h2",
                "label": "H2"
              },
              {
                "value": "h3",
                "label": "H3"
              },
              {
                "value": "p",
                "label": "Paragraphe"
              }
            ],
            "default": "h2"
          }
        ]
      },
      {
        "type": "text",
        "name": "Texte",
        "settings": [
          {
            "type": "richtext",
            "id": "text",
            "label": "Texte",
            "default": "<p>Chaque pièce est façonnée à la main avec passion et savoir-faire.</p>"
          }
        ]
      },
      {
        "type": "button",
        "name": "Bouton",
        "settings": [
          {
            "type": "text",
            "id": "button_label",
            "label": "Texte du bouton",
            "default": "Découvrir"
          },
          {
            "type": "url",
            "id": "button_link",
            "label": "Lien"
          },
          {
            "type": "select",
            "id": "button_style",
            "label": "Style",
            "options": [
              {
                "value": "primary",
                "label": "Plein"
              },
              {
                "value": "secondary",
                "label": "Contour"
              }
            ],
            "default": "primary"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Image + Texte",
        "blocks": [
          {
            "type": "heading",
            "settings": {
              "heading": "Notre savoir-faire"
            }
          },
          {
            "type": "text",
            "settings": {
              "text": "<p>Chaque pièce est façonnée à la main avec passion. Nous perpétuons un savoir-faire artisanal transmis de génération en génération.</p>"
            }
          },
          {
            "type": "button",
            "settings": {
              "button_label": "Découvrir",
              "button_style": "primary"
            }
          }
        ]
      }
    ]
  }
{% endschema %}