<style>


  /*
   ============================================================
   TYPOGRAPHIE — Kitpoterie
   Centralise toutes les règles de taille et style de texte.
   Les valeurs ici écrasent celles de base.css.

   Rappel : 1rem = 10px (avec le scale par défaut du thème)
   Donc 1.4rem = 14px, 1.6rem = 16px, 2rem = 20px, etc.
   ============================================================
*/


  /*
   ============================================================
   CORPS DE TEXTE (paragraphes, texte général)
   ============================================================
*/p {
    font-size: 1.4rem;
    /* 14px */
    line-height: 1.6;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
  }


  /*
   ============================================================
   TITRES (H1 → H6)
   ============================================================
*/

  h1,
  .h1 {
    font-size: 3.2rem;
    /* 32px mobile */
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  @media screen and (min-width: 750px) {
    h1,
    .h1 {
      font-size: 4.8rem;
      /* 48px desktop */
    }
  }

  h2,
  .h2 {
    font-size: 2.4rem;
    /* 24px mobile */
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  @media screen and (min-width: 750px) {
    h2,
    .h2 {
      font-size: 3.2rem;
      /* 32px desktop */
    }
  }

  h3,
  .h3 {
    font-size: 2rem;
    /* 20px mobile */
    line-height: 1.25;
  }

  @media screen and (min-width: 750px) {
    h3,
    .h3 {
      font-size: 2.4rem;
      /* 24px desktop */
    }
  }

  h4,
  .h4 {
    font-size: 1.8rem;
    /* 18px */
    line-height: 1.3;
  }

  h5,
  .h5 {
    font-size: 1.6rem;
    /* 16px */
    line-height: 1.35;
  }

  h6,
  .h6 {
    font-size: 1.4rem;
    /* 14px */
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
  }


  /*
   ============================================================
   LIENS
   ============================================================
*/


  /*
   a {
   font-size: inherit;
   text-decoration: underline;
   }
*/


  /*
   ============================================================
   LABELS / CAPTIONS / PETITS TEXTES
   ============================================================
*/

  .caption,
  .caption-with-letter-spacing {
    font-size: 1.1rem;
    /* 11px */
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .text-body {
    font-size: 1.4rem;
    /* 14px */
    line-height: 1.6;
  }


  /*
   ============================================================
   TEXTE RICHE (pages, articles, descriptions produit)
   Cible le contenu généré par l'éditeur Shopify.
   ============================================================
*/

  .rte p,
  .product__description p {
    font-size: 1.4rem;
    line-height: 1.7;
  }

  .rte h2 {
    font-size: 2.4rem;
  }
  .rte h3 {
    font-size: 2rem;
  }
  .rte h4 {
    font-size: 1.8rem;
  }

</style>