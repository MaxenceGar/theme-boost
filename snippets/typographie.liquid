{% style %}
  /* Application aux éléments */
  p,
  .rte p,
  .product__description p,
  .text-body,
  span {
    font-size: var(--typo-p--size);
    line-height: 1.6;
    letter-spacing: var(--typo-body--letter-spacing);
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
  }

  h1,
  .h1 {
    font-size: var(--typo-h1--size);
    line-height: 1.15;
    letter-spacing: var(--typo-heading--letter-spacing);
  }
  h2,
  .h2 {
    font-size: var(--typo-h2--size);
    line-height: 1.2;
    letter-spacing: var(--typo-heading--letter-spacing);
  }
  h3,
  .h3 {
    font-size: var(--typo-h3--size);
    line-height: 1.25;
  }
  h4,
  .h4 {
    font-size: var(--typo-h4--size);
    line-height: 1.3;
  }
  h5,
  .h5 {
    font-size: var(--typo-h5--size);
    line-height: 1.35;
  }
  h6,
  .h6 {
    font-size: var(--typo-h6--size);
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
  }

  .caption,
  .caption-with-letter-spacing {
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .rte h2 {
    font-size: var(--typo-h2--size);
  }
  .rte h3 {
    font-size: var(--typo-h3--size);
  }
  .rte h4 {
    font-size: var(--typo-h4--size);
  }

  .btn-primaire {
    background-color: var(--color-bg-primaire);
    color: var(--color-text-primaire) !important;
  }

  .btn-secondaire {
    background-color: var(--color-bg-secondaire);
    color: var(--color-text-secondaire) !important;
    border: 1px solid black;
    transition: all 0.3s;
  }

  .btn-secondaire:hover {
    background-color: var(--color-bg-secondaire-hover);
    color: var(--color-text-secondaire-hover) !important;
    border-color: black;
  }

  .btn-tertiaire {
    background-color: black;
    color: white;
    transition: all ease-in-out 0.3s;
  }

  .btn-tertiaire:hover {
    background-color: transparent;
    color: black;
    border: 1px solid black;
  }

  .btn,
  .btn-small {
    align-items: center;
    border-radius: var(--rounded--size) !important;
    display: flex;
    font-size: var(--typo-p--size);
    font-weight: 500;
    justify-content: center;
    letter-spacing: 0.08em;
    line-height: 22px;
    text-align: center;
    text-transform: uppercase;
    transition-duration: 0.2s;
  }

  .btn {
    padding: 12px 32px;
  }
{% endstyle %}