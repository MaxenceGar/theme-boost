{%- liquid
  assign p_size = settings.typo_p_size | divided_by: 10.0
  assign p_mob = settings.typo_p_mobile_size | divided_by: 10.0
  assign h1_desk = settings.typo_h1_size | divided_by: 10.0
  assign h1_mob = settings.typo_h1_mobile_size | divided_by: 10.0
  assign h2_desk = settings.typo_h2_size | divided_by: 10.0
  assign h2_mob = settings.typo_h2_mobile_size | divided_by: 10.0
  assign h3_desk = settings.typo_h3_size | divided_by: 10.0
  assign h3_mob = settings.typo_h3_mobile_size | divided_by: 10.0
  assign h4_desk = settings.typo_h4_size | divided_by: 10.0
  assign h4_mob = settings.typo_h4_mobile_size | divided_by: 10.0
  assign h5_desk = settings.typo_h5_size | divided_by: 10.0
  assign h5_mob = settings.typo_h5_mobile_size | divided_by: 10.0
  assign h6_desk = settings.typo_h6_size | divided_by: 10.0
  assign h6_mob = settings.typo_h6_mobile_size | divided_by: 10.0
  assign radius = settings.border_radius
-%}

{% style %}
  :root  {
    /* Border Radius */
    --rounded--size: {{ settings.border_radius }};

    /* Tailles desktop */
    --typo-p--size: {{ p_size }}rem;
    --typo-h1--size: {{ h1_desk }}rem;
    --typo-h2--size: {{ h2_desk }}rem;
    --typo-h3--size: {{ h3_desk }}rem;
    --typo-h4--size: {{ h4_desk }}rem;
    --typo-h5--size: {{ h5_desk }}rem;
    --typo-h6--size: {{ h6_desk }}rem;

    /* Letter-spacing (s'appuie sur les variables de css-variables.liquid) */
    --typo-heading--letter-spacing: var(--letter-spacing--{{ settings.typo_heading_letter_spacing }});
    --typo-body--letter-spacing: var(--letter-spacing--{{ settings.typo_body_letter_spacing }});
    --letter-spacing--heading-tight: -0.03em;
    --letter-spacing--heading-normal: 0;
    --letter-spacing--heading-loose: 0.03em;

    --letter-spacing--body-tight: -0.03em;
    --letter-spacing--body-normal: 0;
    --letter-spacing--body-loose: 0.03em;
  }

  /* Tailles mobile */
  @media (width < 750px) {
    :root {
      --typo-p--size: {{ p_mob }}rem;
      --typo-h1--size: {{ h1_mob }}rem;
      --typo-h2--size: {{ h2_mob }}rem;
      --typo-h3--size: {{ h3_mob }}rem;
      --typo-h4--size: {{ h4_mob }}rem;
      --typo-h5--size: {{ h5_mob }}rem;
      --typo-h6--size: {{ h6_mob }}rem;
    }
  }

  /* Application aux éléments */
  p,
  .rte p,
  .product__description p,
  .text-body {
    font-size: var(--typo-p--size);
    line-height: 1.6;
    letter-spacing: var(--typo-body--letter-spacing);
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
  }

  h1,
  .h1 {
    font-size: var(--typo-h1--size);
    line-height: 1.15;
    letter-spacing: var(--typo-heading--letter-spacing);
  }
  h2,
  .h2 {
    font-size: var(--typo-h2--size);
    line-height: 1.2;
    letter-spacing: var(--typo-heading--letter-spacing);
  }
  h3,
  .h3 {
    font-size: var(--typo-h3--size);
    line-height: 1.25;
  }
  h4,
  .h4 {
    font-size: var(--typo-h4--size);
    line-height: 1.3;
  }
  h5,
  .h5 {
    font-size: var(--typo-h5--size);
    line-height: 1.35;
  }
  h6,
  .h6 {
    font-size: var(--typo-h6--size);
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
  }

  .caption,
  .caption-with-letter-spacing {
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .rte h2 {
    font-size: var(--typo-h2--size);
  }
  .rte h3 {
    font-size: var(--typo-h3--size);
  }
  .rte h4 {
    font-size: var(--typo-h4--size);
  }

  .btn-primaire {
    background-color: {{ settings.bg_color_primaire }};
    color: {{ settings.text_color_primaire }}
     !important;
  }

  .btn-secondaire {
    background-color: {{ settings.bg_color_secondaire }};
    color: {{ settings.text_color_secondaire }}
     !important;
    border: 1px solid black;
    transition: all 0.3s;
  }

  .btn-secondaire:hover {
    background-color: {{ settings.bg_color_secondaire_hover }};
    color: {{ settings.text_color_secondaire_hover }}
     !important;
    border-color: black;
  }

  .btn-tertiaire {
    background-color: black;
    color: white;
    transition: all ease-in-out 0.3s;
  }

  .btn-tertiaire:hover {
    background-color: transparent;
    color: black;
    border: 1px solid black;
  }

  .btn,
  .btn-small {
    align-items: center;
    border-radius: var(--rounded--size) !important;
    display: flex;
    font-size: var(--typo-p--size);
    font-weight: 500;
    justify-content: center;
    letter-spacing: 0.08em;
    line-height: 22px;
    text-align: center;
    text-transform: uppercase;
    transition-duration: 0.2s;
  }

  .btn {
    padding: 12px 32px;
  }
{% endstyle %}