{%- liquid
  assign goal = 200.0
  assign cart_total = cart.total_price | divided_by: 100.0
  assign progress = cart_total | divided_by: goal | times: 100.0 | round
  if progress > 100
    assign progress = 100
  endif
-%}

<div style="padding: 16px 20px;">
  <div style="height: 6px; background: #e5e5e5; border-radius: 999px; overflow: hidden;">
    <div style="height: 100%; width: {{ progress }}%; background: #000; border-radius: 999px; transition: width 400ms ease;"></div>
  </div>
</div>
