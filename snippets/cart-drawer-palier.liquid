{%- liquid
  assign goal = 20000
  assign cart_total = cart.total_price
  assign progress = cart_total | times: 100 | divided_by: goal
  if progress > 100
    assign progress = 100
  endif
  assign remaining = goal | minus: cart_total
-%}

<div style="padding: 16px 20px;">
  {% if cart_total >= goal %}
    <p>Livraison offerte !</p>
  {% else %}
    <p>Plus que {{ remaining | money }} pour la livraison offerte</p>
  {% endif %}
  <div style="height: 6px; background-color: #e5e5e5; border-radius: 999px; overflow: hidden;">
    <div style="display: block; height: 6px; width: {{ progress }}%; background-color: #000; border-radius: 999px; transition: width 400ms ease;"></div>
  </div>
</div>