{%- comment -%} ====== MODALE (template injecté dans body) ====== {%- endcomment -%}
<template id="pv-modal-tpl-{{ bid }}">
  <div class="video-modal-{{ bid }}">
    <div class="video-modal-inner-{{ bid }}">
      <div class="video-modal-slider-{{ bid }} swiper">
        <div class="swiper-wrapper">

          {%- if has_v1 -%}
            <div class="video-modal-slide-{{ bid }} swiper-slide">
              <div class="video-modal-left-{{ bid }}">
                {%- if product_block.settings.modal_poster_1 != blank -%}
                  <div class="video-modal-poster-{{ bid }}">
                    <img src="{{ product_block.settings.modal_poster_1 | image_url }}" alt="{{ product_block.settings.modal_poster_1.alt }}">
                  </div>
                {%- endif -%}
                {%- if product_block.settings.video_1 == blank and product_block.settings.video_url_1 != blank -%}
                  {%- assign vid1 = product_block.settings.video_url_1.id -%}
                  {%- assign loop1 = '&loop=1&playlist=' | append: vid1 -%}
                  {%- if product_block.settings.video_url_1.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ vid1 }}?enablejsapi=1&mute=1&autoplay=1{{ loop1 }}" data-src="https://www.youtube.com/embed/{{ vid1 }}?enablejsapi=1&mute=1{{ loop1 }}" data-src2="https://www.youtube.com/embed/{{ vid1 }}?enablejsapi=1&autoplay=1{{ loop1 }}" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- else -%}
                    <iframe src="https://player.vimeo.com/video/{{ vid1 }}?mute=1&autoplay=1&loop=1" data-src="https://player.vimeo.com/video/{{ vid1 }}?mute=1&loop=1" data-src2="https://player.vimeo.com/video/{{ vid1 }}?autoplay=1&loop=1" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- endif -%}
                {%- elsif product_block.settings.video_1 != blank -%}
                  <video src="{{ product_block.settings.video_1.sources[1].url }}" muted autoplay playsinline preload="none" loop></video>
                {%- endif -%}
                <div class="video-modal-action-{{ bid }}">{{ svg_mute }}{{ svg_unmute }}</div>
              </div>
            </div>
          {%- endif -%}

          {%- if has_v2 -%}
            <div class="video-modal-slide-{{ bid }} swiper-slide">
              <div class="video-modal-left-{{ bid }}">
                {%- if product_block.settings.modal_poster_2 != blank -%}
                  <div class="video-modal-poster-{{ bid }}">
                    <img src="{{ product_block.settings.modal_poster_2 | image_url }}" alt="{{ product_block.settings.modal_poster_2.alt }}">
                  </div>
                {%- endif -%}
                {%- if product_block.settings.video_2 == blank and product_block.settings.video_url_2 != blank -%}
                  {%- assign vid2 = product_block.settings.video_url_2.id -%}
                  {%- assign loop2 = '&loop=1&playlist=' | append: vid2 -%}
                  {%- if product_block.settings.video_url_2.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ vid2 }}?enablejsapi=1&mute=1&autoplay=1{{ loop2 }}" data-src="https://www.youtube.com/embed/{{ vid2 }}?enablejsapi=1&mute=1{{ loop2 }}" data-src2="https://www.youtube.com/embed/{{ vid2 }}?enablejsapi=1&autoplay=1{{ loop2 }}" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- else -%}
                    <iframe src="https://player.vimeo.com/video/{{ vid2 }}?mute=1&autoplay=1&loop=1" data-src="https://player.vimeo.com/video/{{ vid2 }}?mute=1&loop=1" data-src2="https://player.vimeo.com/video/{{ vid2 }}?autoplay=1&loop=1" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- endif -%}
                {%- elsif product_block.settings.video_2 != blank -%}
                  <video src="{{ product_block.settings.video_2.sources[1].url }}" muted autoplay playsinline preload="none" loop></video>
                {%- endif -%}
                <div class="video-modal-action-{{ bid }}">{{ svg_mute }}{{ svg_unmute }}</div>
              </div>
            </div>
          {%- endif -%}

          {%- if has_v3 -%}
            <div class="video-modal-slide-{{ bid }} swiper-slide">
              <div class="video-modal-left-{{ bid }}">
                {%- if product_block.settings.modal_poster_3 != blank -%}
                  <div class="video-modal-poster-{{ bid }}">
                    <img src="{{ product_block.settings.modal_poster_3 | image_url }}" alt="{{ product_block.settings.modal_poster_3.alt }}">
                  </div>
                {%- endif -%}
                {%- if product_block.settings.video_3 == blank and product_block.settings.video_url_3 != blank -%}
                  {%- assign vid3 = product_block.settings.video_url_3.id -%}
                  {%- assign loop3 = '&loop=1&playlist=' | append: vid3 -%}
                  {%- if product_block.settings.video_url_3.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ vid3 }}?enablejsapi=1&mute=1&autoplay=1{{ loop3 }}" data-src="https://www.youtube.com/embed/{{ vid3 }}?enablejsapi=1&mute=1{{ loop3 }}" data-src2="https://www.youtube.com/embed/{{ vid3 }}?enablejsapi=1&autoplay=1{{ loop3 }}" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- else -%}
                    <iframe src="https://player.vimeo.com/video/{{ vid3 }}?mute=1&autoplay=1&loop=1" data-src="https://player.vimeo.com/video/{{ vid3 }}?mute=1&loop=1" data-src2="https://player.vimeo.com/video/{{ vid3 }}?autoplay=1&loop=1" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- endif -%}
                {%- elsif product_block.settings.video_3 != blank -%}
                  <video src="{{ product_block.settings.video_3.sources[1].url }}" muted autoplay playsinline preload="none" loop></video>
                {%- endif -%}
                <div class="video-modal-action-{{ bid }}">{{ svg_mute }}{{ svg_unmute }}</div>
              </div>
            </div>
          {%- endif -%}

          {%- if has_v4 -%}
            <div class="video-modal-slide-{{ bid }} swiper-slide">
              <div class="video-modal-left-{{ bid }}">
                {%- if product_block.settings.modal_poster_4 != blank -%}
                  <div class="video-modal-poster-{{ bid }}">
                    <img src="{{ product_block.settings.modal_poster_4 | image_url }}" alt="{{ product_block.settings.modal_poster_4.alt }}">
                  </div>
                {%- endif -%}
                {%- if product_block.settings.video_4 == blank and product_block.settings.video_url_4 != blank -%}
                  {%- assign vid4 = product_block.settings.video_url_4.id -%}
                  {%- assign loop4 = '&loop=1&playlist=' | append: vid4 -%}
                  {%- if product_block.settings.video_url_4.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ vid4 }}?enablejsapi=1&mute=1&autoplay=1{{ loop4 }}" data-src="https://www.youtube.com/embed/{{ vid4 }}?enablejsapi=1&mute=1{{ loop4 }}" data-src2="https://www.youtube.com/embed/{{ vid4 }}?enablejsapi=1&autoplay=1{{ loop4 }}" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- else -%}
                    <iframe src="https://player.vimeo.com/video/{{ vid4 }}?mute=1&autoplay=1&loop=1" data-src="https://player.vimeo.com/video/{{ vid4 }}?mute=1&loop=1" data-src2="https://player.vimeo.com/video/{{ vid4 }}?autoplay=1&loop=1" allow="autoplay; encrypted-media" allowfullscreen title="Video"></iframe>
                  {%- endif -%}
                {%- elsif product_block.settings.video_4 != blank -%}
                  <video src="{{ product_block.settings.video_4.sources[1].url }}" muted autoplay playsinline preload="none" loop></video>
                {%- endif -%}
                <div class="video-modal-action-{{ bid }}">{{ svg_mute }}{{ svg_unmute }}</div>
              </div>
            </div>
          {%- endif -%}

        </div>
      </div>

      {%- if video_count > 1 -%}
        <button class="video-modal-prev-{{ bid }}">
          <svg viewBox="0 0 24 24"><path d="m8.5 12.8 5.7 5.6c.4.4 1 .4 1.4 0 .4-.4.4-1 0-1.4l-4.9-5 4.9-5c.4-.4.4-1 0-1.4-.2-.2-.4-.3-.7-.3-.3 0-.5.1-.7.3l-5.7 5.6c-.4.5-.4 1.1 0 1.6 0-.1 0-.1 0 0z"></path></svg>
        </button>
        <button class="video-modal-next-{{ bid }}">
          <svg viewBox="0 0 24 24"><path d="M15.54,11.29,9.88,5.64a1,1,0,0,0-1.42,0,1,1,0,0,0,0,1.41l4.95,5L8.46,17a1,1,0,0,0,0,1.41,1,1,0,0,0,.71.3,1,1,0,0,0,.71-.3l5.66-5.65A1,1,0,0,0,15.54,11.29Z"></path></svg>
        </button>
      {%- endif -%}

    </div>
    <button class="video-modal-close-{{ bid }}">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M12.0002 10.586L4.70718 3.29297L3.29297 4.70718L10.586 12.0002L3.29297 19.2933L4.70718 20.7075L12.0002 13.4145L19.2933 20.7075L20.7075 19.2933L13.4145 12.0002L20.7075 4.70723L19.2933 3.29302L12.0002 10.586Z" fill="white"></path></svg>
    </button>
  </div>
