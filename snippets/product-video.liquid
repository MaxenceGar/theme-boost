{%- comment -%} ====== JS ====== {%- endcomment -%}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>

<script>
  (function() {
    var BID = '{{ bid }}';

    function initPV() {
      var tpl = document.querySelector('#pv-modal-tpl-' + BID);
      if (tpl) document.body.appendChild(tpl.content.firstElementChild);

      setTimeout(function() {
        var modalEl = document.querySelector('.video-modal-' + BID);
        var sliderEl = document.querySelector('.video-modal-slider-' + BID);
        if (!modalEl || !sliderEl) return;

        var slider2 = new Swiper('.video-modal-slider-' + BID, {
          effect: "coverflow",
          speed: 300,
          slidesPerView: 1,
          spaceBetween: 200,
          navigation: {
            nextEl: '.video-modal-next-' + BID,
            prevEl: '.video-modal-prev-' + BID
          },
          coverflowEffect: {
            rotate: 15,
            scale: 0.95,
            stretch: 0,
            depth: 100,
            modifier: 1,
            slideShadows: false
          },
          on: {
            slideChange: function() {
              if (!modalEl.classList.contains('active')) return;
              var slides = this.slides;
              for (var t = 0; t < slides.length; t++) {
                var poster = slides[t].querySelector('.video-modal-poster-' + BID),
                    n = slides[t].querySelector('video'),
                    s = slides[t].querySelector('iframe'),
                    a = slides[t].querySelector('.video-modal-action-' + BID),
                    o, r;
                if (s) {
                  o = s.getAttribute('data-src');
                  r = s.getAttribute('data-src2');
                }
                if (t === this.activeIndex) {
                  if (n) { n.play(); n.muted = false; }
                  if (s) { s.src = r; }
                  if (a) { a.classList.add('active'); }
                  if (poster) { poster.classList.add('active'); }
                } else {
                  if (n) { n.pause(); }
                  if (s) { s.src = o; }
                  if (poster) { poster.classList.remove('active'); }
                }
              }
            }
          }
        });

        var bubbles = document.querySelectorAll('.pv-' + BID + '__bubble');
        var close = document.querySelector('.video-modal-close-' + BID);

        bubbles.forEach(function(el, index) {
          el.addEventListener('click', function() {
            slider2.slideTo(index);
            var activeSlide = slider2.slides[index];
            var video = activeSlide.querySelector('video');
            var frame = activeSlide.querySelector('iframe');
            var src2 = frame ? frame.getAttribute('data-src2') : null;
            var btn = activeSlide.querySelector('.video-modal-action-' + BID);
            setTimeout(function() {
              document.body.style.overflow = 'hidden';
              modalEl.classList.add('active');
              if (video) { video.play(); video.muted = false; }
              if (btn) { btn.classList.add('active'); }
              if (frame && src2) { frame.src = src2; }
            }, 200);
          });
        });

        function closeModal() {
          document.body.style.overflow = '';
          modalEl.classList.remove('active');
          modalEl.querySelectorAll('iframe').forEach(function(el) {
            var src1 = el.getAttribute('data-src');
            el.src = src1;
            if (el.src.includes('youtube.com')) {
              el.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
            } else if (el.src.includes('vimeo.com')) {
              el.contentWindow.postMessage('{"method":"pause"}', '*');
            }
          });
          modalEl.querySelectorAll('video').forEach(function(el) {
            el.pause();
            el.currentTime = 0;
            el.muted = true;
          });
        }

        close.addEventListener('click', closeModal);
        document.addEventListener('click', function(e) {
          if (e.target === modalEl) closeModal();
        });

        document.querySelectorAll('.video-modal-slide-' + BID).forEach(function(el) {
          var btn = el.querySelector('.video-modal-action-' + BID);
          var frame = el.querySelector('iframe');
          var src2 = frame ? frame.getAttribute('data-src2') : null;
          var video = el.querySelector('video');
          if (btn) {
            btn.addEventListener('click', function() {
              btn.classList.toggle('active');
              if (btn.classList.contains('active')) {
                if (frame) { frame.src = src2; }
                if (video) { video.muted = false; }
              } else {
                if (frame) { frame.src = frame.getAttribute('data-src'); }
                if (video) { video.muted = true; }
              }
            });
          }
        });

      }, 400);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPV);
    } else {
      initPV();
    }
  })();
</script>

