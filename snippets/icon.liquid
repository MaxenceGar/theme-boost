{%- comment -%}
  Snippet pour afficher des icones SVG

  Paramètres:
  - icon: le nom de l'icone (arrow, citation, stone, ball, check)
  - width: largeur en px (ex: '24px', '14px')
  - height: hauteur en px (ex: '24px', '14px')

  Utilisation:
  {% render 'icon', icon: 'arrow', width: '24px', height: '24px' %}
{%- endcomment -%}

{% case icon %}
  {% when 'arrow' %}
    <svg
      fill="#000000"
      width="{{ width }}"
      height="{{ height }}"
      viewBox="0 0 15 15"
      xmlns="http://www.w3.org/2000/svg"
      id="arrow">
