{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}"></script>

{%- style -%}
  #MediaGallery-{{ section.id }} {
    display: flex;
    flex-direction: column-reverse;
    width: 100%;
    gap: 12px;
  }

  .pg-thumbs-{{ section.id }} {
    display: none;
    flex-direction: row;
    gap: 8px;
    width: 500px;
  }

  @media (min-width: 750px) {
    .pg-thumbs-{{ section.id }} {
      display: flex;
    }
  }

  .pg-thumbs-{{ section.id }}
  .pg-thumb {
    cursor: pointer;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .pg-thumbs-{{ section.id }}
  .pg-thumb.is-active {
    border-color: currentColor;
  }

  .pg-thumbs-{{ section.id }}.pg-thumb:hover {
    opacity: 0.8;
  }

  .pg-thumbs-{{ section.id }}
  img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .pg-main-{{ section.id }} {
    width: 100%;
  }

  #ProductGallerySwiper-{{ section.id }} {
    width: 100%;
  }

  #ProductGallerySwiper-{{ section.id }}
  img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }
{%- endstyle -%}

<media-gallery
  id="MediaGallery-{{ section.id }}"
  role="region"
  aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
  {% if section.settings.enable_sticky_info %}
  class="product__column-sticky"
  {% endif %}>

  <!-- Thumbnails (desktop uniquement) -->
  <div class="pg-thumbs-{{ section.id }}">
    {% for media in product.media %}
      <div class="pg-thumb{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
        <img
          src="{{ media.preview_image | image_url: width: 200 }}"
          alt="{{ media.alt | escape }}"
          loading="lazy">
      </div>
    {% endfor %}
  </div>

  <!-- Grande image (Swiper) -->
  <div class="pg-main-{{ section.id }}">
    <div class="swiper" id="ProductGallerySwiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for media in product.media %}
          <div class="swiper-slide" data-media-id="{{ section.id }}-{{ media.id }}">
            <img
              src="{{ media.preview_image | image_url: width: 1200 }}"
              srcset="
                {{ media.preview_image | image_url: width: 600 }} 600w,
                {{ media.preview_image | image_url: width: 900 }} 900w,
                {{ media.preview_image | image_url: width: 1200 }} 1200w
              "
              sizes="(min-width: 750px) 50vw, 100vw"
              alt="{{ media.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          </div>
        {% endfor %}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>

</media-gallery>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var galleryEl = document.getElementById('MediaGallery-{{ section.id }}');
    var swiperEl = document.getElementById('ProductGallerySwiper-{{ section.id }}');
    if (!galleryEl || !swiperEl) return;

    var swiper = new Swiper(swiperEl, {
      slidesPerView: 1,
      pagination: {
        el: swiperEl.querySelector('.swiper-pagination'),
        clickable: true,
      },
    });

    var thumbs = galleryEl.querySelectorAll('.pg-thumb');

    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        swiper.slideTo(parseInt(thumb.dataset.index));
      });
    });

    swiper.on('slideChange', function () {
      thumbs.forEach(function (t) { t.classList.remove('is-active'); });
      if (thumbs[swiper.activeIndex]) {
        thumbs[swiper.activeIndex].classList.add('is-active');
      }
    });

    galleryEl.setActiveMedia = function (mediaId) {
      var index = Array.from(swiper.slides).findIndex(function (s) {
        return s.dataset.mediaId === mediaId;
      });
      if (index >= 0) swiper.slideTo(index);
    };
  });
</script>