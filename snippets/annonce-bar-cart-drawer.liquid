{{ 'block-annonce-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign icon = block.settings.icon
  assign has_icon = false
  if icon != blank
    assign has_icon = true
  endif

  if block.settings.bg_type == 'gradient'
    assign bg_style = 'background: linear-gradient(' | append: block.settings.gradient_direction | append: ', ' | append: block.settings.bg_color | append: ', ' | append: block.settings.bg_color_2 | append: ');'
  else
    assign bg_style = 'background-color: ' | append: block.settings.bg_color | append: ';'
  endif
-%}

<div
  class="annonce-bar"
  style="{{ bg_style }} padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px; color: {{ block.settings.text_color }};"
  {{ block.shopify_attributes }}>
  <div class="annonce-bar__content">

    {%- if has_icon and block.settings.icon_position == 'before' -%}
      <img
        class="annonce-bar__icon"
        src="{{ icon | image_url: width: 64 }}"
        alt=""
        width="{{ block.settings.icon_size }}"
        height="{{ block.settings.icon_size }}"
        loading="lazy">
    {%- endif -%}

    <span class="annonce-bar__text">{{ block.settings.text | escape }}</span>

    {%- if has_icon and block.settings.icon_position == 'after' -%}
      <img
        class="annonce-bar__icon"
        src="{{ icon | image_url: width: 64 }}"
        alt=""
        width="{{ block.settings.icon_size }}"
        height="{{ block.settings.icon_size }}"
        loading="lazy">
    {%- endif -%}

  </div>
</div>
