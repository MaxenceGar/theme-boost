    "faq_product_page_9RC7rB": {
      "type": "faq-product-page",
      "blocks": {
        "faq_section_49YHVi": {
          "type": "faq_section",
          "settings": {
            "question": "Comment puis-je personnaliser un bijou ?",
            "reponse": "Vous pouvez personnaliser votre bijou en sélectionnant le modèle souhaité et en ajoutant une gravure de votre choix. Les options de personnalisation varient selon le type de bijou, comme des médailles, bagues et bracelets."
          }
        },
        "faq_section_JaHcQg": {
          "type": "faq_section",
          "settings": {
            "question": "Offrez-vous la livraison gratuite ?",
            "reponse": "La livraison est offerte en France pour toute commande à partir de 150€. Nous expédions également à l'international avec des frais de livraison calculés lors de la commande."
          }
        },
        "faq_section_A3frix": {
          "type": "faq_section",
          "settings": {
            "question": "Comment entretenir mes bijoux personnalisés ?",
            "reponse": "Pour préserver l'éclat de vos bijoux, nous vous recommandons de les nettoyer régulièrement avec un chiffon doux et de les ranger dans un pochon ou dans un endroit sec, à l'abri de la lumière directe, de l'humidité et des produits chimiques."
          }
        },
        "faq_section_VGQddW": {
          "type": "faq_section",
          "settings": {
            "question": "Proposez-vous des emballages cadeaux ?",
            "reponse": "Oui, tous nos bijoux sont livrés dans un pochon raffiné Nouvel Amour, prêt à offrir. Vous pouvez également ajouter un message personnalisé pour rendre votre cadeau encore plus spécial. Pour une présentation encore plus élégante, une boîte cadeau est également disponible à l'achat."
          }
        }
