{% doc %}
  @example
  {% content_for 'block', type: 'text', id: 'text' %}
{% enddoc %}

{% if block.settings.img %}
    <img
          src="{{ block.settings.img | image_url }}"
          alt=""
          class="aspect-3/2 {{ block.settings.image_ratio }} object-cover rounded-lg">
{% endif %}

{% content_for 'blocks' %}

{% style %}

.image-block__image {
    object-fit: cover;
    aspect-ratio: var(--ratio);
    width: 100%;
  }

{% endstyle %}

{% schema %}
{
  "name": "Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "aspect_ratio",
      "options": [
        {
          "value": "aspect-video",
          "label": "aspect-video"
        },
        {
          "value": "aspect-square",
          "label": "aspect-square"
        }
      ],
      "default": "aspect-video"
    }
  ],
  "presets": [
    {
        "name": "Image"
    }
  ]
}
{% endschema %}
